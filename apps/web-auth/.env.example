# Auth Mode: 'local' (開発用) or 'supabase' (本番用)
# ローカルモードでは apps/web-auth の dev:auth サーバーを使用
VITE_AUTH_MODE=local
VITE_LOCAL_AUTH_SERVER=http://localhost:3001

# Supabase Configuration (VITE_AUTH_MODE=supabase の場合に必要)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ログイン後に access_token 付きリダイレクトを許可する origin（カンマ区切り）
# localhost / 127.0.0.1 は常に許可されます
VITE_ALLOWED_REDIRECT_ORIGINS=https://claude.ai,https://chatgpt.com
